# Required: OpenRouter API key for LLM chat functionality
# Get one at https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data
# If not set, the built-in market simulator is used (recommended for most users)
MASSIVE_API_KEY=

# Optional: Set to "true" for deterministic mock LLM responses (testing/development)
LLM_MOCK=false

# Environment — controls SSL verification for outbound LLM calls.
# Leave as "development" locally (disables SSL cert check to work behind corporate proxies
# such as Zscaler). Set to "production" on cloud deployments to re-enable verification.
# See backend/app/llm/service.py → call_llm() for full details and the go-live checklist.
ENVIRONMENT=development

# Internal configuration (usually no need to change)
# DB_PATH=/app/db/finally.db
# STATIC_DIR=/app/static
